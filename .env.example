# Supabase — get these from your project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Admin dashboard password (change before deploying)
ADMIN_PASSWORD=your-secure-password

# Gmail SMTP — used to send order notification emails
# Use an App Password (not your Gmail login password)
# Generate at: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email address that receives order notifications
ORDER_NOTIFICATION_EMAIL=your-email@example.com
